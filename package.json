{
  "name": "aidm",
  "version": "0.0.1",
  "private": true,
  "description": "AIDM v4 — anime-themed long-horizon single-player TTRPG dungeon master",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prompts:dump": "tsx scripts/dump-prompts.ts",
    "eval": "tsx scripts/run-evals.ts",
    "eval:fast": "tsx scripts/run-evals.ts --fast",
    "eval:long": "tsx scripts/run-evals.ts --long",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@clerk/nextjs": "^6.0.0",
    "@google/genai": "^0.10.0",
    "@mastra/core": "^0.10.0",
    "@tanstack/react-query": "^5.60.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.0",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "openai": "^4.70.0",
    "pg": "^8.13.0",
    "posthog-js": "^1.170.0",
    "posthog-node": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.28.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
