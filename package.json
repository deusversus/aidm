{
  "name": "aidm",
  "version": "0.0.1",
  "private": true,
  "description": "AIDM v5 — an engine for co-telling long-form fiction that stays true to a premise",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "spike:judgment": "tsx --env-file=.env.local scripts/spike-judgment.ts",
    "spike:narration": "tsx --env-file=.env.local scripts/spike-narration.ts",
    "spike:embed": "tsx --env-file=.env.local scripts/spike-embed.ts",
    "spike:prewarm": "tsx --env-file=.env.local scripts/spike-prewarm.ts",
    "evals": "tsx --env-file=.env.local evals/run.ts",
    "evals:ci": "tsx evals/run.ts --ci",
    "grounding:check": "tsx scripts/grounding-check.ts",
    "research": "tsx --env-file=.env.local scripts/research.ts",
    "soak": "tsx --env-file=.env.local scripts/soak.ts",
    "langfuse:latest": "tsx --env-file=.env.local scripts/langfuse-latest.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@anthropic-ai/sdk": "^0.90.0",
    "@clerk/nextjs": "^7.2.3",
    "drizzle-orm": "^0.36.0",
    "langfuse": "^3.38.20",
    "next": "^15.1.0",
    "pg": "^8.13.0",
    "posthog-js": "^1.369.3",
    "posthog-node": "^5.29.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svix": "^1.90.0",
    "voyageai": "^0.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.28.0",
    "js-yaml": "^4.1.1",
    "langfuse-cli": "^0.0.9",
    "playwright-core": "^1.61.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
