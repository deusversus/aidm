# --- Database ---
# Paste the Railway Postgres public URL here (Railway project → Postgres plugin → Variables tab).
# Public URL format: postgresql://postgres:PASSWORD@SUBDOMAIN.proxy.rlwy.net:PORT/DBNAME
# v5 uses a fresh database (aidm_v5) on the same instance — never point this at
# the v4 database. When the app runs ON Railway, DATABASE_URL is injected automatically.
# No local Postgres — dev runs against the Railway-hosted database directly.
DATABASE_URL=""

# --- Auth (Clerk) ---
# Clerk dashboard → API Keys: copy publishable + secret keys.
# Webhook signing secret comes from Clerk dashboard → Webhooks after creating an
# endpoint at {NEXT_PUBLIC_APP_URL}/api/webhooks/clerk subscribed to
# user.created + user.updated + user.deleted.
#
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is inlined into the CLIENT bundle at BUILD time.
# It must be present in Railway's build environment, not just runtime, or Clerk
# will throw in the browser on every page load.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# Clerk redirect URLs — without these, Clerk defaults to hosted pages for some
# flows (accounts.clerk.com) instead of our in-app /sign-in and /sign-up routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/campaigns
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/campaigns

# --- LLM ---
# Anthropic-only for story generation (blueprint §3). Tier menus:
# narration Sonnet 5 / Opus 4.8 / Fable 5 · judgment Haiku 4.5 / Sonnet 5 / Opus 4.8
# · probe Haiku 4.5 / Sonnet 5.
ANTHROPIC_API_KEY=""
# Voyage — the named embedding exception (Anthropic has no embeddings API).
# voyage-3.5 @ 1024 dimensions, frozen at M0.
VOYAGE_API_KEY=""

# --- Observability ---
# Langfuse: LLM tracing. Per-trace prompt + cost + latency + eval scores.
# US region; .eu. and self-hosted variants exist.
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://us.cloud.langfuse.com"

# PostHog: product analytics + session replay + error tracking + feature flags.
# Public key is inlined into the CLIENT bundle at build time; must be set in
# Railway's build environment for prod.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- App ---
# Local dev: http://localhost:3000
# Production: the Railway-issued domain (e.g. https://aidm-production-f9f7.up.railway.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
