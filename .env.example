# --- Database ---
# Paste the Railway Postgres public URL here (Railway project → Postgres plugin → Variables tab).
# Public URL format: postgresql://postgres:PASSWORD@SUBDOMAIN.proxy.rlwy.net:PORT/railway
# When the app runs ON Railway, DATABASE_URL is injected automatically (internal URL).
# No local Postgres — dev runs against the Railway-hosted database directly.
DATABASE_URL=""

# --- Auth (Clerk) ---
# Clerk dashboard → API Keys: copy publishable + secret keys.
# Webhook signing secret comes from Clerk dashboard → Webhooks after creating an
# endpoint at {NEXT_PUBLIC_APP_URL}/api/webhooks/clerk subscribed to
# user.created + user.updated + user.deleted.
#
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is inlined into the CLIENT bundle at BUILD time.
# It must be present in Railway's build environment, not just runtime, or Clerk
# will throw in the browser on every page load.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# Clerk redirect URLs — without these, Clerk defaults to hosted pages for some
# flows (accounts.clerk.com) instead of our in-app /sign-in and /sign-up routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/campaigns
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/campaigns

# --- App ---
# Local dev: http://localhost:3000
# Production: the Railway-issued domain (e.g. https://aidm-production-f9f7.up.railway.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
