# --- Database ---
# Paste the Railway Postgres public URL here (Railway project → Postgres plugin → Variables tab).
# Public URL format: postgresql://postgres:PASSWORD@SUBDOMAIN.proxy.rlwy.net:PORT/railway
# When the app runs ON Railway, DATABASE_URL is injected automatically (internal URL).
# No local Postgres — dev runs against the Railway-hosted database directly.
DATABASE_URL=""

# --- LLM providers ---
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_API_KEY=""
OPENROUTER_API_KEY=""

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# --- Observability ---
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"

NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- Payments (M9) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- App ---
# Local dev: http://localhost:3000
# Production: the Railway-issued domain (e.g. https://aidm.up.railway.app or a custom domain)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
