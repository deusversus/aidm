# LLM Provider Selection
# Options: google, anthropic, openai (auto-detects based on available keys if not set)
LLM_PROVIDER=google

# Google Gemini (Primary - most affordable)
# Models: gemini-3-flash-preview (fast), gemini-3-pro-preview (creative)
GOOGLE_API_KEY=your-google-api-key

# Anthropic Claude (Best creative writing)
# Models: claude-haiku-4-5 (fast), claude-sonnet-4-5 (creative), claude-opus-4-5 (best)
# Set ANTHROPIC_CREATIVE_MODEL=opus to use Opus instead of Sonnet for creative tasks
# Opus 4.5 is now nearly Sonnet pricing - great for premium narrative quality
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_CREATIVE_MODEL=sonnet

# OpenAI ChatGPT (Most widely used)
# Models: gpt-5.2-chat-latest (fast), gpt-5.2-pro (creative)
OPENAI_API_KEY=your-openai-api-key

# Model Overrides (optional - uses provider defaults if not set)
# FAST_MODEL=gemini-3-flash-preview
# CREATIVE_MODEL=gemini-3-pro-preview

# Database
DATABASE_URL=postgresql://aidm:aidm@localhost:5432/aidm

# Observability (optional — Langfuse)
# Option A: Langfuse Cloud — sign up at https://langfuse.com
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com  # omit for EU region (default)
#
# Option B: Self-hosted via docker compose --profile langfuse (see setup.sh / README)
# LANGFUSE_SECRET_KEY=local-secret-key
# LANGFUSE_PUBLIC_KEY=local-public-key
# LANGFUSE_HOST=http://langfuse:3000

# Debug
DEBUG=true
LOG_AGENT_DECISIONS=true

# Session Zero Compiler feature flags
# Set to 'true' to enable the new HandoffCompiler at SZ→gameplay handoff.
# All three flags are independent — start with COMPILER_ENABLED to test extraction.
SESSION_ZERO_COMPILER_ENABLED=false
SESSION_ZERO_DEDICATED_OPENING_SCENE_ENABLED=false
SESSION_ZERO_ORCHESTRATOR_ENABLED=false
