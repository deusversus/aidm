# AIDM .gitignore
# Based on backup_aidm.ps1 exclusions

# === SENSITIVE FILES (NEVER COMMIT) ===
apikeys_unencrypted
.env
!.env.example
settings.json
# GitHub Copilot — any raw/unencrypted token dumps
copilot_token*
github_token*

# === Virtual Environments ===
venv/
venv313/
Lib/
Include/
share/
Scripts/
pyvenv.cfg

# === Dependencies ===
node_modules/

# === Python Artifacts ===
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/

# === Data & Runtime ===
chroma/
test_chroma/
data/
*.db
*.sqlite

# === Logs & Backups ===
*.log
log/
logs/
backup/
*.zip

# === Scratch / temp files ===
tmp_query.py
pr_diff*.txt

# === IDE & System ===
.git/
.vscode/
*.swp
*.swo
Thumbs.db
.DS_Store

# === Agent & CI (local-only) ===
.agent/
.github/
.claude/

# === Generated profiles (auto-regenerated from DB) ===
src/profiles/catalog/*.yaml
